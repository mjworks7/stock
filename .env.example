# Copy this file to ".env" and fill in your key.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model used by the analyst agents.
# STOCKADVISOR_MODEL=claude-opus-4-8

# ── 선택: 한국투자증권(KIS) OpenAPI — 국내 종목 정밀 데이터 ──────────────
# 발급: https://apiportal.koreainvestment.com (앱 등록 후 APP KEY/SECRET)
# 설정하면 국내(6자리) 종목은 KIS 로, 해외 종목은 무료 공급자로 조회합니다.
# 미설정 시 전 종목 무료(yfinance/FDR) 공급자로 동작합니다.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_PAPER=0          # 1 이면 모의투자 도메인 사용
